---
import DocsLayout from "../layouts/DocsLayout.astro";
import { getDocsByCategory } from "../lib/component-docs";
import { docsPath } from "../lib/paths";

const categories = Array.from(getDocsByCategory().entries());
const total = categories.reduce((count, [, docs]) => count + docs.length, 0);
---

<DocsLayout
  title="Component Documentation"
  description="DuskMoon React component documentation with API references and demos."
>
  <section class="hero">
    <h1>DuskMoon React Components</h1>
    <p>
      API references, usage demos, and DuskMoon theme previews for every
      implemented component in the package.
    </p>
    <div class="hero-actions">
      <a class="button-link" href={docsPath("/components/button")}>Start with Button</a>
      <a class="button-link" href={docsPath("/components/dm-provider")}>Theme Provider</a>
    </div>
  </section>

  {categories.map(([category, docs]) => (
    <section class="category">
      <h2>{category}</h2>
      <p>{docs.length} of {total} documented components.</p>
      <div class="component-grid">
        {docs.map((component) => (
          <a class="component-card" href={component.route}>
            <strong>{component.title}</strong>
            <span>{component.id}</span>
          </a>
        ))}
      </div>
    </section>
  ))}
</DocsLayout>
