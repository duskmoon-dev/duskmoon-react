---
import DocsLayout from "../../layouts/DocsLayout.astro";
import DemoRenderer from "../../components/DemoRenderer";
import {
  getComponentDoc,
  getComponentDocs,
  getDocsByCategory,
  type ComponentDoc,
} from "../../lib/component-docs";

export function getStaticPaths() {
  return getComponentDocs().map((component) => ({
    params: { id: component.id },
    props: { component },
  }));
}

const { component } = Astro.props as { component: ComponentDoc };
const categories = Array.from(getDocsByCategory().entries());

if (!getComponentDoc(component.id)) {
  return Astro.redirect("/");
}
---

<DocsLayout title={component.title} description={component.intro}>
  <div class="doc-shell">
    <aside class="side-nav" aria-label="Component sections">
      <div class="nav-section">
        <a href="#intro">Intro</a>
        <a href="#api">API</a>
        <a href="#demos">Demos</a>
        <a href="/">All components</a>
      </div>

      {categories.map(([category, docs]) => (
        <div class="nav-group">
          <div class="nav-group-title">{category}</div>
          <div class="nav-group-items">
            {docs.map((item) => (
              <a
                href={item.route}
                class={`nav-item ${item.id === component.id ? "active" : ""}`}
              >
                {item.title}
              </a>
            ))}
          </div>
        </div>
      ))}
    </aside>

    <article class="doc-content">
      <header id="intro" class="doc-title">
        <div class="badge-row">
          <span class="badge">{component.category}</span>
          <span class="badge">{component.source}</span>
          <span class="badge">{component.status}</span>
        </div>
        <h1>{component.title}</h1>
        <p>{component.intro}</p>
        <p class="meta">
          Import from <code>{component.importPath}</code>
        </p>
        {component.keyProps.length > 0 ? (
          <div class="meta-panel">
            <strong>Key API</strong>
            <div class="tag-list">
              {component.keyProps.map((prop) => <code>{prop}</code>)}
            </div>
          </div>
        ) : null}
        {component.scenarios.length > 0 ? (
          <div class="meta-panel">
            <strong>Documented scenarios</strong>
            <ul>
              {component.scenarios.slice(0, 6).map((scenario) => (
                <li>{scenario}</li>
              ))}
            </ul>
          </div>
        ) : null}
      </header>

      <section id="api" class="section">
        <h2>API</h2>
        <p>
          API tables are generated from the component TypeScript type definitions.
        </p>
        {component.api.length === 0 ? (
          <div class="empty-state">No dedicated props interface was found.</div>
        ) : (
          component.api.map((section) => (
            <div class="api-card">
              <header>
                <strong>{section.name}</strong>
                <span class="api-meta">
                  {section.kind}
                  {section.extendsText ? ` extends ${section.extendsText}` : ""}
                </span>
              </header>
              {section.definition ? (
                <pre><code>{section.definition}</code></pre>
              ) : section.props.length > 0 ? (
                <table class="api-table">
                  <thead>
                    <tr>
                      <th>Prop</th>
                      <th>Type</th>
                      <th>Required</th>
                      <th>Description</th>
                    </tr>
                  </thead>
                  <tbody>
                    {section.props.map((prop) => (
                      <tr>
                        <td><code>{prop.name}</code></td>
                        <td><code>{prop.type}</code></td>
                        <td>{prop.required ? "Yes" : "No"}</td>
                        <td>{prop.description || `${prop.name} configures ${component.title}.`}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              ) : (
                <div class="empty-state">No direct props declared.</div>
              )}
            </div>
          ))
        )}
      </section>

      <section id="demos" class="section">
        <h2>Demos</h2>
        <div class="demo-grid">
          {component.demos.map((demo) => (
            <div class="demo-card">
              <div
                class={`demo-preview ${component.category === "CSS Art" ? "art-demo-preview" : ""}`}
              >
                <DemoRenderer
                  componentId={component.id}
                  componentName={component.title}
                  demoTitle={demo.title}
                  demoCode={demo.code}
                  client:load
                />
              </div>
              <div class="demo-body">
                <h3>{demo.title}</h3>
                <p>{demo.description}</p>
                <pre><code>{demo.code}</code></pre>
              </div>
            </div>
          ))}
        </div>
      </section>
    </article>
  </div>
</DocsLayout>
