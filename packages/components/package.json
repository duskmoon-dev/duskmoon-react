  "scripts": {
    "build": "rm -rf dist && bun run build:js && bun run build:types && bun run build:css",
    "build:js": "bun run build.ts",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "build:css": "mkdir -p dist && cp node_modules/@duskmoon-dev/core/dist/index.css dist/styles.css",
    "test": "bun test --preload ../../test/setup.ts",
    "test:a11y": "bun test --preload ../../test/setup.ts src/**/*.test.tsx",
    "typecheck": "tsc --noEmit",
    "parity:components": "bun run scripts/check-component-parity.ts",
    "size": "bundlesize"
  },
  "bundlesize": [
    {
      "path": "./dist/**/*.js",
      "maxSize": "100 kB"
    }
  ],
