{
  "name": "duskmoon-react-monorepo",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "bun run --filter \"@duskmoon-dev/docs\" dev",
    "build:all": "bun run --filter '*' build",
    "build": "bun run --filter \"@duskmoon-dev/components\" build",
    "test": "bun run --filter \"@duskmoon-dev/components\" test && bun run --filter \"@duskmoon-dev/art-components\" test",
    "lint": "bun run lint:all",
    "lint:all": "bun x eslint .",
    "lint:check": "bun x eslint .",
    "format": "bun x prettier --write .",
    "format:check": "bun x prettier --check .",
    "typecheck": "bun run --filter '*' typecheck",
    "parity:components": "bun run --filter \"@duskmoon-dev/components\" parity:components",
    "release": "bun run release:check-versions && changeset publish --no-git-tag",
    "release:version": "changeset version && bun run release:sync-versions",
    "release:sync-versions": "bun run scripts/release-versions.mjs sync",
    "release:check-versions": "bun run scripts/release-versions.mjs check",
    "release:version-current": "bun run --silent scripts/release-versions.mjs current",
    "release:dry-run": "bun run release:check-versions"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@happy-dom/global-registrator": "20.10.2",
    "@playwright/test": "^1.60.0",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "bundlesize": "^0.18.2",
    "eslint": "10.4.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "happy-dom": "20.10.2",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0"
  }
}
